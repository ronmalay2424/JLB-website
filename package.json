{
  "name": "jlb-website",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "wrangler dev",
    "deploy": "astro build && wrangler deploy",
    "astro": "astro",
    "cf-typegen": "wrangler types",
    "db:migrate:local": "wrangler d1 migrations apply jlb-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply jlb-db --remote",
    "db:studio:local": "wrangler d1 execute jlb-db --local --command \"SELECT name FROM sqlite_master WHERE type='table'\""
  },
  "dependencies": {
    "@astrojs/cloudflare": "^14.1.3",
    "astro": "^7.1.0",
    "resend": "^6.17.2",
    "wrangler": "^4.111.0"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "sharp@0.34.5": true,
    "sharp@0.35.3": true,
    "workerd@1.20260710.1": true
  },
  "devDependencies": {
    "@types/node": "^26.1.1"
  }
}

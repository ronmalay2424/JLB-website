---
import site from '../data/site.json';

// Three interchangeable landing-screen treatments. The homepage picks one;
// /hero-options previews all of them so the band can choose.
interface Props {
	variant?: 'logo' | 'photo' | 'photo-color' | 'cinematic';
}

const { variant = 'logo' } = Astro.props;
---

<section class:list={['hero', `hero--${variant}`]}>
	{variant === 'photo' && <div class="hero-bg hero-bg--photo" aria-hidden="true" />}
	{variant === 'photo-color' && <div class="hero-bg hero-bg--photo-color" aria-hidden="true" />}
	{variant === 'cinematic' && <div class="hero-bg hero-bg--cinematic" aria-hidden="true" />}
	<div class="hero-overlay" aria-hidden="true" />

	{/* photo variants: transparent logo up top, faces clear mid-frame,
	    tagline + actions at the bottom */}
	{variant === 'photo' || variant === 'photo-color' ? (
		<div class="hero-content hero-content--split">
			<img
				class="hero-logo hero-logo--transparent"
				src="/images/uploads/jlb_logo_transparent.png"
				alt={site.bandName}
				width="1100"
				height="733"
				loading="eager"
			/>
			<h1 class="visually-hidden">{site.bandName}</h1>
			<div class="hero-bottom">
				<p class="hero-tagline">{site.tagline}</p>
				<div class="hero-actions">
					<a class="btn btn--solid" href="/#shows">Upcoming shows</a>
					<a class="btn" href="/#contact">Join the mailing list</a>
				</div>
			</div>
		</div>
	) : (
		<div class="hero-content">
			{variant === 'cinematic' ? (
				<>
					<img
						class="hero-logo hero-logo--small"
						src="/images/uploads/JLB_Logo.jpg"
						alt=""
						width="160"
						height="126"
						loading="eager"
					/>
					<h1 class="hero-name">{site.bandName}</h1>
				</>
			) : (
				<>
					<img
						class="hero-logo"
						src="/images/uploads/JLB_Logo.jpg"
						alt={site.bandName}
						width="420"
						height="330"
						loading="eager"
					/>
					<h1 class="visually-hidden">{site.bandName}</h1>
				</>
			)}
			<p class="hero-tagline">{site.tagline}</p>
			<div class="hero-actions">
				<a class="btn btn--solid" href="/#shows">Upcoming shows</a>
				<a class="btn" href="/#contact">Join the mailing list</a>
			</div>
		</div>
	)}

	<a class="hero-scroll" href="/#shows" aria-label="Scroll down">
		<span></span>
	</a>
</section>

<style>
	.hero {
		position: relative;
		min-height: 100svh;
		display: flex;
		align-items: center;
		justify-content: center;
		text-align: center;
		overflow: hidden;
		padding: 6rem 1.5rem 4rem;
	}

	/* --- backgrounds --- */
	.hero--logo {
		background:
			radial-gradient(ellipse 60% 45% at 50% 42%, rgba(201, 163, 95, 0.13), transparent 70%),
			var(--bg);
	}

	.hero-bg {
		position: absolute;
		inset: 0;
		background-size: cover;
		background-position: center 30%;
		animation: kenburns 24s ease-in-out infinite alternate;
	}

	.hero-bg--photo {
		background-image: url('/images/uploads/BW_band.jpg');
		background-position: center 35%;
	}

	.hero-bg--photo-color {
		background-image: url('/images/uploads/band_outside_color.jpg');
		background-position: center 35%;
	}

	.hero-bg--cinematic {
		background-image: url('/images/uploads/band_outside_color.jpg');
	}

	@keyframes kenburns {
		from { transform: scale(1); }
		to { transform: scale(1.09); }
	}

	@media (prefers-reduced-motion: reduce) {
		.hero-bg { animation: none; }
	}

	/* Keep the middle of the frame (faces) bright; darken top for the nav and
	   bottom for the tagline/buttons. */
	.hero--photo .hero-overlay,
	.hero--photo-color .hero-overlay {
		position: absolute;
		inset: 0;
		background: linear-gradient(
			180deg,
			rgba(11, 10, 8, 0.5) 0%,
			rgba(11, 10, 8, 0.12) 32%,
			rgba(11, 10, 8, 0.18) 58%,
			rgba(11, 10, 8, 0.88) 100%
		);
	}

	.hero--cinematic .hero-overlay {
		position: absolute;
		inset: 0;
		background: linear-gradient(160deg, rgba(11, 10, 8, 0.25) 30%, rgba(11, 10, 8, 0.9) 85%);
	}

	/* --- content --- */
	.hero-content {
		position: relative;
		z-index: 1;
		animation: heroIn 1.4s ease both;
	}

	@keyframes heroIn {
		from { opacity: 0; transform: translateY(18px); }
		to { opacity: 1; transform: none; }
	}

	.hero-logo {
		width: min(420px, 78vw);
		height: auto;
		margin: 0 auto;
		mix-blend-mode: screen;
		filter: drop-shadow(0 0 42px rgba(201, 163, 95, 0.28));
	}

	.hero-logo--small {
		width: 150px;
		margin-bottom: 0.6rem;
	}

	/* --- photo variants: logo top, faces clear, actions bottom --- */
	.hero--photo,
	.hero--photo-color {
		align-items: stretch;
		padding-bottom: 0;
	}

	.hero-content--split {
		display: flex;
		flex-direction: column;
		justify-content: space-between;
		align-items: center;
		width: 100%;
	}

	.hero-logo--transparent {
		width: min(360px, 64vw);
		height: auto;
		mix-blend-mode: normal;
		filter: drop-shadow(0 6px 26px rgba(0, 0, 0, 0.55)) drop-shadow(0 1px 3px rgba(0, 0, 0, 0.4));
	}

	.hero-bottom {
		margin-bottom: 5.5rem;
	}

	.hero-name {
		font-size: clamp(2.6rem, 8vw, 4.6rem);
		letter-spacing: 0.06em;
		text-shadow: 0 2px 30px rgba(0, 0, 0, 0.65);
	}

	.hero-tagline {
		margin-top: 1.2rem;
		color: var(--cream-dim);
		font-family: var(--font-display);
		font-size: clamp(1.15rem, 2.6vw, 1.5rem);
		font-style: italic;
		letter-spacing: 0.04em;
	}

	.hero--photo .hero-tagline,
	.hero--photo-color .hero-tagline,
	.hero--cinematic .hero-tagline {
		color: var(--cream);
		text-shadow: 0 1px 18px rgba(0, 0, 0, 0.7);
	}

	.hero-actions {
		margin-top: 2.4rem;
		display: flex;
		gap: 1rem;
		justify-content: center;
		flex-wrap: wrap;
	}

	/* --- scroll cue --- */
	.hero-scroll {
		position: absolute;
		bottom: 2rem;
		left: 50%;
		transform: translateX(-50%);
		width: 26px;
		height: 42px;
		border: 1px solid var(--gold-dim);
		border-radius: 14px;
		z-index: 1;
	}

	.hero-scroll span {
		position: absolute;
		top: 8px;
		left: 50%;
		width: 3px;
		height: 8px;
		margin-left: -1.5px;
		border-radius: 2px;
		background: var(--gold);
		animation: scrollcue 1.8s ease-in-out infinite;
	}

	@keyframes scrollcue {
		0% { opacity: 0; transform: translateY(0); }
		40% { opacity: 1; }
		100% { opacity: 0; transform: translateY(12px); }
	}

	.visually-hidden {
		position: absolute;
		width: 1px;
		height: 1px;
		overflow: hidden;
		clip: rect(0 0 0 0);
	}
</style>
